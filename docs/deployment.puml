@startuml deployment
title Déploiement - AuditRegistry

node "Navigateur\nutilisateur" as Browser {
  component "Frontend React\n(Wagmi · Viem · AppKit)" as UI
}

cloud "Vercel cloud" {
  component "Build Vite\n(dist statique)" as Vercel
}

cloud "Sepolia Testnet" as Chain {
  node "Smart Contracts" {
    component "AuditRegistry"           as Registry
    component "ReputationBadge\n(ERC721 soul-bound)" as Badge
    component "AuditEscrow\n(pull payment)" as Escrow
    component "MockUSDC\n(ERC20)"       as USDC
    component "MockTreasury"            as Treasury
    component "MockDAOVoting"           as DAO
  }
}

node "Machine développeur" {
  component "Hardhat Node\n(réseau local)" as HardhatLocal
  component "deployAllAndSeed.ts"       as Seed
}

Browser  --> Vercel      : HTTPS
UI       --> Registry    : eth_call / eth_sendTransaction\n(WalletConnect RPC)
UI       --> Badge       : eth_call

Seed     --> Chain       : déploiement + seed\n(--network sepolia)
Seed     --> Vercel      : écrit frontend/.env\n(adresses + DEPLOY_BLOCK)

Registry --> Badge    : mintNft() · incAudits() · incExploits()
Registry --> Escrow   : lockFunds() · releasePayment()\nreleaseGuarantee() · refund()
Registry --> USDC     : transferFrom()
Registry --> Treasury : transfer(5 %)
Registry --> DAO      : createIncident() · hasIncident()

@enduml
